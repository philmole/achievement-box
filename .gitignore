!fpga/prebuilt/mega-pro.rbf

# Node / webui build
node_modules/
dist/

# OS noise
Thumbs.db
.DS_Store

# rc_client debug artifacts
patch_dump.json

# RA credentials (see daemon/.env.example)
daemon/.env

# web/daemon cache (badges, box art, OpenVGDB, library index)
daemon/cache/
daemon/webapp-crash.log

# Playwright visual-check scratch output
.playwright-mcp/
abox-*.png

# stray MSVC objects from the rcheevos DLL build
*.obj

