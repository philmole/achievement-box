# Copy to daemon/.env and fill in. The .env file is gitignored; it is loaded
# on startup by daemon/config.py. Real environment variables override it.

# --- RetroAchievements login (required) ---
RA_USER=
RA_PASS=

# --- Local web UI login (optional) ---
# Blank password = trusted-local-network mode with no browser login prompt.
# If set, use a unique password (not RA_PASS); WEB_USER is then the login name.
WEB_USER=achievementbox
WEB_PASSWORD=

# When optional web authentication is enabled, keep this at 1 so Basic
# credentials are never sent over clear-text LAN HTTP.
WEB_REQUIRE_HTTPS=1

# --- Identification and media policy ---
# Preferred box-art release. Aliases include PAL, USA/NTSC-U and NTSC-J.
# Use ROM to prefer the region already present in each ROM filename.
MEDIA_REGION=Europe

# --- Mega Drive path (only needed for the MED Pro / MD path) ---
# krikzz edlink.exe -- USB link tool. External dependency, NOT shipped here.
# Upstream: https://github.com/krikzz/mega-ed-pub
# Included as the references/mega-ed-pub Git submodule; initialize submodules
# and leave this blank. Only set it when edlink.exe lives somewhere else.
MED_EDLINK=

# Sniffer core flashed onto the Mega EverDrive Pro. Defaults to the shipped
# fpga/prebuilt/mega-pro.rbf; override to test a fresh Quartus build.
MED_CORE_RBF=

# Mega Drive games folder on the cart's SD card (where the achievements toggle
# stages mapper.rbf). Defaults to "MEGA DRIVE".
MD_ROM_DIR=
